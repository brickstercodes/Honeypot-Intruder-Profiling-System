# Admin console
ADMIN_PASSWORD=change-me-now
ADMIN_COOKIE_NAME=hp_admin_session
ADMIN_COOKIE_SECRET=replace-this-secret

# Main dashboard app
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
TRAP_PREVIEW_PATH=/trap

# Decoy ports
DECOY_SSH_ENABLED=true
DECOY_SSH_PORT=2222
DECOY_FTP_ENABLED=true
DECOY_FTP_PORT=2121
DECOY_TELNET_ENABLED=true
DECOY_TELNET_PORT=2323
DECOY_HTTP_ENABLED=true
DECOY_HTTP_PORT=8081
DECOY_DATABASE_ENABLED=true
DECOY_DATABASE_PORT=33060

# Detection / response
AUTO_BLOCK_THRESHOLD=82
TERMINATE_HIGH_RISK=true
SNAPSHOT_LIMIT=120

# GeoIP
GEOIP_ENABLED=true

# Alerting: Discord webhook
DISCORD_WEBHOOK_URL=

# Alerting: Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alerting: Email via Resend API
RESEND_API_KEY=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# Isolation notes shown on dashboard
ISOLATION_MODE=container
ISOLATION_NOTE_1=Run inside Docker, VM, or a segmented lab network.
ISOLATION_NOTE_2=Keep admin console private. Only expose decoy ports.
ISOLATION_NOTE_3=Do not route real production traffic through the honeypot.

# Secure relay (3rd device — AES-256-GCM encrypted channel)
# Set RELAY_ENABLED=true to activate. Snapshot is sent then self-destructed from source.
RELAY_ENABLED=false
RELAY_RECEIVER_PORT=5000
RELAY_RECEIVER_URL=http://localhost:5000
RELAY_ENCRYPTION_KEY=change-this-relay-key

# Optional simulation shortcut
SIMULATION_COUNT=16

VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=